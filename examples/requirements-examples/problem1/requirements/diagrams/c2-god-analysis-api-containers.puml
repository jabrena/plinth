@startuml c2-god-analysis-api-containers
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Container Diagram — God Analysis API (C4 Level 2)

Person(api_consumer, "API Consumer", "Client calling the statistics endpoint")

System_Boundary(god_analysis_boundary, "God Analysis API") {
    Container(rest_app, "REST application", "Spring Boot 4, Java 25+", "Exposes JSON REST API, virtual-thread parallel fetches, RestClient timeouts, partial results on source timeout, Spring Boot Actuator (health, metrics, info)")
}

System_Ext(greek_data, "Greek mythology data API", "REST JSON arrays of god names")
System_Ext(roman_data, "Roman mythology data API", "REST JSON arrays of god names")
System_Ext(nordic_data, "Nordic mythology data API", "REST JSON arrays of god names")

Rel(api_consumer, rest_app, "GET /api/v1/gods/stats/sum", "HTTPS/JSON")
Rel(rest_app, greek_data, "GET god names", "HTTPS/JSON")
Rel(rest_app, roman_data, "GET god names", "HTTPS/JSON")
Rel(rest_app, nordic_data, "GET god names", "HTTPS/JSON")

@enduml
