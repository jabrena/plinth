@startuml c1-god-analysis-api-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title System Context — God Analysis API (C4 Level 1)

Person(api_consumer, "API Consumer", "Client application or operator calling the statistics endpoint")

System(god_analysis_api, "God Analysis API", "Spring Boot service that aggregates mythology god names and returns a Unicode sum for a filter character")

System_Ext(greek_data, "Greek mythology data API", "REST JSON source for Greek god names (configurable URL)")
System_Ext(roman_data, "Roman mythology data API", "REST JSON source for Roman god names (configurable URL)")
System_Ext(nordic_data, "Nordic mythology data API", "REST JSON source for Nordic god names (configurable URL)")

Rel(api_consumer, god_analysis_api, "GET /api/v1/gods/stats/sum (filter, sources)", "HTTPS/JSON")
Rel(god_analysis_api, greek_data, "Fetches god name arrays", "HTTPS/JSON")
Rel(god_analysis_api, roman_data, "Fetches god name arrays", "HTTPS/JSON")
Rel(god_analysis_api, nordic_data, "Fetches god name arrays", "HTTPS/JSON")

@enduml
