@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Cursor Rules Generator - Container Diagram

Person(dev, "Developer", "Runs builds and tests")

System_Boundary(sys, "Cursor Rules Generator") {
  Container(cli, "Generator CLI/Library", "Java 24", "Transforms XML/XSL into MDC")
  ContainerDb(fs, "Filesystem", "Local FS", "Stores XML, XSL, MDC outputs")
}

System_Ext(maven, "Maven", "Build and dependency management")

Rel(dev, cli, "Invokes via mvn test/package")
Rel(cli, fs, "Reads XML/XSL, writes MDC")
Rel(cli, maven, "Uses plugins at build time")

@enduml

