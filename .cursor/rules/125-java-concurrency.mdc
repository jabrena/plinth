## Rule 9: Simplify Concurrent Code with Structured Concurrency

Title: Manage Related Tasks as a Single Unit
Description:
Use `StructuredTaskScope` to simplify the management of multiple related concurrent tasks as a single unit of work, improving error handling, cancellation, and resource management.
- Use `StructuredTaskScope.ShutdownOnFailure()` for fail-fast behavior.
- Use `StructuredTaskScope.ShutdownOnSuccess()` for racing tasks.
- Ensure proper resource cleanup with try-with-resources.
- Handle task results and exceptions appropriately.
- Combine structured concurrency with virtual threads for optimal performance.

**Good example:**

```java
import java.util.concurrent.StructuredTaskScope;
import java.util.concurrent.Future;
import java.util.concurrent.Executors;
import java.util.concurrent.ExecutorService;
import java.util.List;
import java.util.concurrent.TimeUnit;

class StructuredConcurrencyExample {

    private final ExecutorService virtualExecutor = Executors.newVirtualThreadPerTaskExecutor();

    // Example: Fetch user data from multiple sources
    // Note: StructuredTaskScope is a preview feature in Java 19+ and may require --enable-preview flag
    public UserData fetchCompleteUserData(String userId) throws Exception {
        try (var scope = new StructuredTaskScope.ShutdownOnFailure()) {

            // Fork multiple related tasks
            Future<Profile> profileFuture = scope.fork(() -> fetchUserProfile(userId));
            Future<Settings> settingsFuture = scope.fork(() -> fetchUserSettings(userId));
            Future<List<Order>> ordersFuture = scope.fork(() -> fetchUserOrders(userId));
            Future<List<Notification>> notificationsFuture = scope.fork(() -> fetchUserNotifications(userId));

            // Wait for all tasks to complete or fail
            scope.join();
            scope.throwIfFailed(); // Propagate any failures

            // All tasks completed successfully - access results
            return new UserData(
                profileFuture.resultNow(),
                settingsFuture.resultNow(),
                ordersFuture.resultNow(),
                notificationsFuture.resultNow()
            );
        }
    }

    // Example: Race multiple service calls and return first success
    public String fetchDataFromAnySource(String query) throws Exception {
        try (var scope = new StructuredTaskScope.ShutdownOnSuccess<String>()) {

            // Fork tasks that compete to provide result
            scope.fork(() -> fetchFromPrimaryService(query));
            scope.fork(() -> fetchFromSecondaryService(query));
            scope.fork(() -> fetchFromCacheService(query));

            // Wait for first successful completion
            scope.join();

            // Return the first successful result
            return scope.result();
        }
    }

    // Example: Batch processing with structured concurrency
    public List<ProcessedItem> processBatch(List<String> items) throws Exception {
        try (var scope = new StructuredTaskScope.ShutdownOnFailure()) {

            // Fork processing tasks for each item
            List<Future<ProcessedItem>> futures = items.stream()
                .map(item -> scope.fork(() -> processItem(item)))
                .toList();

            // Wait for all processing to complete
            scope.join();
            scope.throwIfFailed();

            // Collect all results
            return futures.stream()
                .map(Future::resultNow)
                .toList();
        }
    }

    // Example: Timeout handling with structured concurrency
    public String fetchWithTimeout(String request, long timeoutSeconds) throws Exception {
        try (var scope = new StructuredTaskScope.ShutdownOnFailure()) {

            // Fork the main task
            Future<String> resultFuture = scope.fork(() -> performLongRunningTask(request));

            // Fork timeout task
            Future<String> timeoutFuture = scope.fork(() -> {
                Thread.sleep(timeoutSeconds * 1000);
                throw new TimeoutException("Operation timed out after " + timeoutSeconds + " seconds");
            });

            // Wait for either completion or timeout
            scope.join();
            scope.throwIfFailed();

            // Return result if main task completed first
            return resultFuture.resultNow();
        }
    }

    // Helper methods simulating various operations
    private Profile fetchUserProfile(String userId) {
        simulateIO(100);
        return new Profile(userId, "John Doe", "john@example.com");
    }

    private Settings fetchUserSettings(String userId) {
        simulateIO(150);
        return new Settings(userId, "dark", "en");
    }

    private List<Order> fetchUserOrders(String userId) {
        simulateIO(200);
        return List.of(new Order("order1", 100.0), new Order("order2", 250.0));
    }

    private List<Notification> fetchUserNotifications(String userId) {
        simulateIO(120);
        return List.of(new Notification("Welcome!"), new Notification("Order shipped"));
    }

    private String fetchFromPrimaryService(String query) {
        simulateIO(300);
        return "Primary result for: " + query;
    }

    private String fetchFromSecondaryService(String query) {
        simulateIO(200);
        return "Secondary result for: " + query;
    }

    private String fetchFromCacheService(String query) {
        simulateIO(50);
        return "Cached result for: " + query;
    }

    private ProcessedItem processItem(String item) {
        simulateIO(100);
        return new ProcessedItem(item, "processed");
    }

    private String performLongRunningTask(String request) {
        simulateIO(5000); // 5 seconds
        return "Completed: " + request;
    }

    private void simulateIO(int milliseconds) {
        try {
            Thread.sleep(milliseconds);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
            throw new RuntimeException(e);
        }
    }

    // Data classes
    record UserData(Profile profile, Settings settings, List<Order> orders, List<Notification> notifications) {}
    record Profile(String userId, String name, String email) {}
    record Settings(String userId, String theme, String language) {}
    record Order(String id, double amount) {}
    record Notification(String message) {}
    record ProcessedItem(String original, String status) {}

    class TimeoutException extends Exception {
        public TimeoutException(String message) {
            super(message);
        }
    }
}
