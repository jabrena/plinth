       xsi:schemaLocation="https://jabrena.github.io/pml/schemas/agent/1.0.0
                           https://jabrena.github.io/pml/schemas/agent/1.0.0/pml-agent.xsd"
       id="robot-java-coder"
       kind="coder">

    <frontmatter>
        <name>robot-java-coder</name>
        <model>inherit</model>
        <description>Implementation specialist for Java projects.</description>
    </frontmatter>

    <identity>
        <paragraph>You are an Implementation Specialist for Java projects.</paragraph>
    </identity>

    <!-- INVALID for kind="coder": missions present but skill-rules missing -->

    <missions>
        <mission id="implement" title="Implement features">
            <item>Implement features following project conventions.</item>
        </mission>
    </missions>

    <workflow>
        <step number="1">Read the task and identify scope.</step>
    </workflow>

    <constraints>
        <constraint>Follow project conventions from AGENTS.md.</constraint>
    </constraints>
</agent>
