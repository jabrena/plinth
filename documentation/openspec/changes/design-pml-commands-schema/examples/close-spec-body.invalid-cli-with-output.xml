<?xml version="1.0" encoding="UTF-8"?>
<command xmlns="https://jabrena.github.io/pml/schemas/command/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jabrena.github.io/pml/schemas/command/1.0.0
                             https://jabrena.github.io/pml/schemas/command/1.0.0/pml-command.xsd"
         id="close-spec"
         kind="cli"
         slash="/close-spec">

    <purpose>
        <paragraph>Archive an OpenSpec change by name using the OpenSpec CLI.</paragraph>
    </purpose>

    <usage>/close-spec &lt;change-name&gt;</usage>

    <accepted-inputs>
        <input>change-name: the OpenSpec change name to archive</input>
    </accepted-inputs>

    <owning-agent>robot-architect</owning-agent>

    <workflow>
        <step number="1">Validate the argument is present.</step>
    </workflow>

    <!-- INVALID for kind="cli": output section forbidden -->

    <output>
        <item>Success message including change-name</item>
    </output>

    <safeguards>
        <constraint>Do not claim success when openspec archive fails.</constraint>
    </safeguards>
</command>
